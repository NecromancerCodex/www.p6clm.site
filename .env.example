# CLM 백엔드 서버 URL
# - 로컬 venv 실행: http://localhost:8002
# - Docker Compose 실행: http://clm:8002  (서비스명 사용)
CLM_SERVER_API_URL=http://localhost:8002

# 브라우저(클라이언트)에서 직접 접근할 때 사용 (NEXT_PUBLIC_ 필수)
# Next.js rewrites를 사용하면 아래 값은 사용되지 않음
NEXT_PUBLIC_CLM_API_URL=http://localhost:8002

# 인증 백엔드 root URL (027 Google 로그인) — GOOGLE_REDIRECT_URI 포트와 일치
# 로컬: http://localhost:8080  프로덕션: https://api.clm.site
NEXT_PUBLIC_API_BASE=http://localhost:8080
